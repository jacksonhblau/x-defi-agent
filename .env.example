# =============================================================================
# DeFi X Posting Agent - environment variables
# =============================================================================
# 1. Copy this file to .env in the same directory:
#       cp .env.example .env
# 2. Fill in real values in .env (NOT in this file).
# 3. Never commit .env. The .gitignore in this folder already excludes it.
# =============================================================================


# -----------------------------------------------------------------------------
# X / Twitter API (developer.x.com)
# -----------------------------------------------------------------------------
# Get from: https://developer.x.com/en/portal/dashboard
#   Project > App > Keys and tokens tab
# Make sure User authentication settings = Read and Write BEFORE generating
# the Access Token, otherwise it won't have write scope.
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
# The handle the agent posts as (no @, just the screen name)
X_HANDLE=jacksonblau


# -----------------------------------------------------------------------------
# Anthropic API (console.anthropic.com)
# -----------------------------------------------------------------------------
# Get from: https://console.anthropic.com > Settings > API Keys
# Recommend setting a monthly spend cap in the console as a safety rail.
ANTHROPIC_API_KEY=
# Model to use for draft generation (overridable per-task)
ANTHROPIC_MODEL=claude-opus-4-6


# -----------------------------------------------------------------------------
# Supabase (supabase.com)
# -----------------------------------------------------------------------------
# Get from: Project > Settings > API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
# Get from: Project > Settings > Database > Connection string > URI
# Use the "Transaction pooler" connection string for workers.
DATABASE_URL=


# -----------------------------------------------------------------------------
# Alchemy (alchemy.com)
# -----------------------------------------------------------------------------
# Get from: dashboard.alchemy.com > Your App
ALCHEMY_API_KEY=
ALCHEMY_ETH_MAINNET_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# Optional, will add as the agent expands beyond Ethereum L1
ALCHEMY_BASE_RPC=
ALCHEMY_ARBITRUM_RPC=


# -----------------------------------------------------------------------------
# Telegram (my.telegram.org)
# -----------------------------------------------------------------------------
# Get from: https://my.telegram.org > API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Phone number of the Telegram account the agent logs in as
# (with country code, e.g. +15551234567)
TELEGRAM_PHONE=
# Session file path (Telethon will create this on first login)
TELEGRAM_SESSION_PATH=./data/telegram.session
# Comma-separated channel usernames to subscribe to
TELEGRAM_CHANNELS=RWAxyzNewswire


# -----------------------------------------------------------------------------
# RWA.xyz API (email them for access)
# -----------------------------------------------------------------------------
# Email: support@rwa.xyz to request API access. Leave blank until provisioned.
RWA_XYZ_API_KEY=
RWA_XYZ_BASE_URL=https://api.rwa.xyz


# -----------------------------------------------------------------------------
# DeFiLlama (mostly public, no key needed for core endpoints)
# -----------------------------------------------------------------------------
# Only set if you upgrade to Pro for higher rate limits.
DEFILLAMA_API_KEY=


# -----------------------------------------------------------------------------
# VaultsFYI
# -----------------------------------------------------------------------------
# Check vaults.fyi for current API access process.
VAULTSFYI_API_KEY=


# -----------------------------------------------------------------------------
# Bubblemaps
# -----------------------------------------------------------------------------
# Currently scraped via Playwright; only set if/when they offer official API.
BUBBLEMAPS_API_KEY=


# -----------------------------------------------------------------------------
# Etherscan (for fallback contract lookups + ABI fetching)
# -----------------------------------------------------------------------------
# Get from: etherscan.io > My API Keys
ETHERSCAN_API_KEY=


# -----------------------------------------------------------------------------
# App config
# -----------------------------------------------------------------------------
# Password for the review UI (single-user; pick something long).
REVIEW_UI_PASSWORD=
# JWT signing secret for review UI sessions (any random 64+ char string).
REVIEW_UI_JWT_SECRET=
# Materiality score threshold (0-100). Stories at or above this get drafted.
MATERIALITY_THRESHOLD=60
# Novelty score threshold (0-100).
NOVELTY_THRESHOLD=50
# Max posts per day the agent will queue. Algo-refit (May 2026): dropped from 8 to 3
# to stay below the X author-dilution rail; Jackson's call from the Q&A.
DAILY_POST_CAP=3
# Hot-take generator cron (cron syntax, default 11am ET = 15:00 UTC)
HOT_TAKE_CRON=0 15 * * *
# Weekly recap cron (default Friday 9am ET = 13:00 UTC)
WEEKLY_RECAP_CRON=0 13 * * 5


# -----------------------------------------------------------------------------
# Higgsfield (editorial / concept imagery — see docs/higgsfield_integration.md)
# -----------------------------------------------------------------------------
# Dev path: Higgsfield MCP server is wired into the Cowork/Claude Code runtime
# (tools prefixed `mcp__39dcce27-…`). No env needed for that path.
# Prod path: Higgsfield REST API (enterprise — request access at cloud.higgsfield.ai)
HIGGSFIELD_MCP_URL=https://mcp.higgsfield.ai/mcp
HIGGSFIELD_REST_URL=https://cloud.higgsfield.ai/api/v1
HIGGSFIELD_API_KEY=
HIGGSFIELD_DEFAULT_IMAGE_MODEL=flux-2
HIGGSFIELD_DEFAULT_VIDEO_MODEL=kling-3
# Refuse new generations once monthly credit spend exceeds this.
HIGGSFIELD_CREDIT_MONTHLY_CAP=2000


# -----------------------------------------------------------------------------
# OpenAI — backs the production image generation path (gpt-image-1)
# -----------------------------------------------------------------------------
# Algo-refit final: every post's infographic is generated via OpenAI's
# gpt-image-1 (same model Higgsfield's gpt_image_2 wraps). The model knows
# authentic brand logos for the entities we care about — Tether, BlackRock,
# Ethereum, TRON, OFAC, etc. — so plates get contextual visual cues instead
# of generic icons. Required for production on Fly.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
# Quality: low (cheapest), medium (default, ~$0.04 per 1024x1024), high
OPENAI_IMAGE_QUALITY=medium


# -----------------------------------------------------------------------------
# Canva (data-led brand templates — see docs/canva_integration.md)
# -----------------------------------------------------------------------------
# Dev path: Canva MCP server is wired into the Cowork/Claude Code runtime
# (tools prefixed `mcp__96182097-…`). No env needed for that path.
# Prod path: Canva Connect REST API — requires Canva Enterprise OAuth.
# Algo-refit Q&A decision: skip the Enterprise upgrade for now; use MCP in dev,
# defer prod REST wire-up until templates are stable.
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_REFRESH_TOKEN=
CANVA_BRAND_ORG_ID=


# -----------------------------------------------------------------------------
# Object storage (for rendered graphics)
# -----------------------------------------------------------------------------
# Start with Supabase Storage (already covered above). Optional R2 later.
# CLOUDFLARE_R2_ACCOUNT_ID=
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_BUCKET=


# -----------------------------------------------------------------------------
# Observability (optional, recommend adding before going live)
# -----------------------------------------------------------------------------
# SENTRY_DSN=
# AXIOM_TOKEN=


# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
# 'development' for local, 'production' on Fly.io
NODE_ENV=development
LOG_LEVEL=info
